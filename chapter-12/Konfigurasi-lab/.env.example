# Salin: cp .env.example .env

SPARK_REPO_DIR=./vendor/bigdata-spark
SPARK_CONTAINER=bigdata-spark
SPARK_JOBS_DIR=/opt/spark-jobs

# JDBC dari kontainer Spark ke PostgreSQL (viz-postgres di host)
# Mac/Windows Docker Desktop:
PG_JDBC_URL=jdbc:postgresql://host.docker.internal:5432/analytics
# Linux (gateway default):
# PG_JDBC_URL=jdbc:postgresql://172.17.0.1:5432/analytics

PG_USER=superset
PG_PASSWORD=superset
