<?xml version="1.0"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!--
  Klien HBase di dalam image sburn/apache-atlas memuat /apache-atlas/hbase/conf
  sebelum properti JanusGraph; bawaan image sering memakai localhost:2181 →
  ReadOnlyZKClient ke 127.0.0.1. Override ini agar mengarah ke service Docker `hbase`.
-->
<configuration>
  <property>
    <name>hbase.zookeeper.quorum</name>
    <value>hbase</value>
  </property>
  <property>
    <name>hbase.zookeeper.property.clientPort</name>
    <value>2181</value>
  </property>
  <property>
    <name>zookeeper.znode.parent</name>
    <value>/hbase</value>
  </property>
  <property>
    <name>hbase.security.authentication</name>
    <value>simple</value>
  </property>
  <!-- Saat HBase baru naik: PleaseHoldException, /hbase/master belum ada, meta belum di ZK — perpanjang retry klien -->
  <property>
    <name>hbase.client.retries.number</name>
    <value>45</value>
  </property>
  <property>
    <name>hbase.client.pause</name>
    <value>250</value>
  </property>
</configuration>
